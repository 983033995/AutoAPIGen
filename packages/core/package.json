  "description": "Core logic for AutoAPIGen — HTTP requests, code generation utilities (no VSCode dependency)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
