    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "prettier-plugin-organize-imports": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/prettier": "^3.0.0"
