{
  "name": "@zhangheteng/aag-cli",
  "version": "1.0.0",
  "description": "CLI tool for AutoAPIGen — query Apifox APIs and generate TypeScript code from .vscode/autoApiGen.json",
  "main": "./dist/index.js",
  "bin": {
    "aag": "./dist/bin/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "983033995",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/bin/cli.js"
  },
  "dependencies": {
    "@zhangheteng/aag-core": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "inquirer": "^8.2.6",
    "fs-extra": "^11.2.0",
    "prettier": "3.3.2",
    "pinyin-pro": "^3.23.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/inquirer": "^8.2.10",
    "@types/fs-extra": "^11.0.4"
  },
  "keywords": [
    "apifox",
    "api",
    "codegen",
    "typescript",
    "cli"
  ],
  "license": "MIT"
}
